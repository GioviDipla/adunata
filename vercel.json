{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/cron/daily-sync/route.ts": {
      "memory": 3008,
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "0 3 * * *"
    }
  ]
}
